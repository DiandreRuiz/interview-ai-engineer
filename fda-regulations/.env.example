# Copy to .env and adjust. Values are read by pydantic-settings (see fda_regulations.config.Settings).

# Directory containing index_manifest.json, chunks.jsonl, embeddings.npy, chunk_order.json.
ARTIFACT_ROOT=artifacts

# If true, the app exits at startup when the manifest or directory is missing.
REQUIRE_ARTIFACTS=true

# Reciprocal rank fusion constant k (implementation-plan appendix; HybridRetriever at query time).
RRF_K=60

# Candidate pool sizes before RRF (BM25 and dense each contribute a ranked list).
SEARCH_TOP_K_SPARSE=50
SEARCH_TOP_K_DENSE=50

# Sentence-transformers model id for ``fda-build-index`` (local bi-encoder).
# INDEX_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Ingest (warning letters HTML) ---
FDA_USER_AGENT="fda-regulations-poc/0.1 (research; add contact URL if you run against production FDA)"
# INGEST_LISTING_BASE_URL defaults to the FDA warning letters hub URL (shell page).
# INGEST_LISTING_BATCH_SIZE=100   # DataTables ``length`` per AJAX request (1–500).
# INGEST_MAX_LISTING_PAGES=   # unset = page DataTables until catalog ends (max AJAX batches after shell GET)
# INGEST_MAX_LETTERS=         # unset = no cap after discovery
INGEST_REQUEST_DELAY_SECONDS=0.5

# Optional: override raw corpus directory (default: ARTIFACT_ROOT/corpus).
# INGEST_CORPUS_DIR=artifacts/corpus
