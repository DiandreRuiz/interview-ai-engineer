# Copy to .env and adjust. Values are read by pydantic-settings (see fda_regulations.config.Settings).

# Directory containing index_manifest.json (and future BM25 / embedding artifacts).
ARTIFACT_ROOT=artifacts

# If true, the app exits at startup when the manifest or directory is missing.
REQUIRE_ARTIFACTS=true

# Reciprocal rank fusion constant k (implementation-plan appendix; used by future hybrid retriever).
RRF_K=60

# Candidate pool sizes before RRF (future hybrid retriever).
SEARCH_TOP_K_SPARSE=50
SEARCH_TOP_K_DENSE=50
